<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Global Switch</title>
    <style>
        body { font-family: sans-serif; text-align: center; padding: 2rem; background: #f5f5f5; }
        button { padding: 1rem 2rem; font-size: 1.5rem; margin-top: 1rem; cursor: pointer; border-radius: 8px; border: none; background-color: #007bff; color: #fff; transition: 0.2s; }
        button:hover { background-color: #0056b3; }
        img { margin-top: 2rem; border: 2px solid #333; border-radius: 4px; }
    </style>
</head>
<body>
    <h1>?? Global Switch</h1>
    <p>Click the button to toggle the switch:</p>
    <button id="toggleBtn">Toggle Switch</button>

    <h2>Live Video</h2>
    <img id="cameraFeed" src="" alt="Live Stream" width="640" height="480">


    <script>
        // ?? Replace these URLs with your Ngrok HTTPS URLs
        const API_URL = 'https://delia-unsifted-georgie.ngrok-free.dev';  // Flask toggle API
        const MJPEG_URL = 'https://abcd1234.ngrok-free.dev/?action=stream'; // MJPEG stream HTTPS URL

        const toggleBtn = document.getElementById('toggleBtn');
        const cameraFeed = document.getElementById('cameraFeed');

        // Set MJPEG feed
        cameraFeed.src = MJPEG_URL;

        // Toggle button click
        toggleBtn.addEventListener('click', async () => {
            try {
                const res = await fetch(`${API_URL}/toggle`, { method: 'POST' });
                if (!res.ok) throw new Error('Network response not OK');
                const data = await res.json();
                alert(`Switch state: ${data.state ? 'ON' : 'OFF'}`);
            } catch (err) {
                alert(`Error toggling light: ${err.message}`);
                console.error(err);
            }
        });
    </script>
</body>
</html>
